# Desktop (Electron) renderer build — the app talks to the bundled market
# engine on localhost. Consumed by `vite build --mode desktop`; these flow
# through the existing VITE_API_URL / VITE_WS_URL overrides in src (no code
# changes). Fixed port per desktop architecture decision #3.
VITE_API_URL=http://127.0.0.1:8000
VITE_WS_URL=ws://127.0.0.1:8000/ws/stream
