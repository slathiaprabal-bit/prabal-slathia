{
  "name": "ps-terminal",
  "productName": "PS Terminal",
  "description": "Quantitative Trading Platform",
  "author": "Prabal Slathia",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "main": "electron/main/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "build:desktop": "vite build --mode desktop",
    "desktop": "npm run build:desktop && electron .",
    "desktop:dev": "electron .",
    "desktop:engine": "pyinstaller --clean --noconfirm desktop/engine.spec",
    "desktop:pack": "electron-builder --win",
    "desktop:dist": "npm run build:desktop && npm run desktop:pack"
  },
  "dependencies": {
    "electron-log": "^5.4.4"
  },
  "devDependencies": {
    "@google/genai": "^1.29.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/d3": "^7.4.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "better-sqlite3": "^12.4.1",
    "d3": "^7.9.0",
    "dotenv": "^17.2.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.0.12",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.14",
    "three": "^0.171.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "zustand": "^5.0.14"
  }
}
